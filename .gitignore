# ==========================================
# Git 忽略文件配置
# ==========================================

# ==================== 依赖目录 ====================
node_modules/
**/node_modules/

# ==================== 环境配置 ====================
# 【重要】.env 包含敏感信息，不要提交到 Git
.env
.env.local
.env.production

# ==================== 数据库文件 ====================
# 【重要】用户数据不要提交到 Git
*.db
*.db-journal
*.db-wal
*.db-shm
db/
database/

# ==================== 上传文件 ====================
# 【重要】用户上传的文件不要提交到 Git
uploads/
# docs/
music/
books/
code/
private/

# ==================== 日志文件 ====================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ==================== IDE 配置 ====================
.vscode/
.idea/
*.swp
*.swo
*~

# ==================== 操作系统文件 ====================
.DS_Store
Thumbs.db

# ==================== 构建输出 ====================
dist/
build/
*.tgz

# ==================== 测试覆盖率 ====================
coverage/
.nyc_output/

# ==================== 临时文件 ====================
*.tmp
*.temp
.cache/
.temp/

# ==================== Docker 相关 ====================
docker-compose.override.yml

# ==================== 项目特定 ====================
# 会话历史文件
history_*.md

# 配置文件（包含域名等敏感信息）
backend/data/booksearch-config.json

# 私密文档（如果存在）
private_documents/
