# ==========================================
# 个人资源管理系统 - 环境配置模板
# ==========================================
# 复制此文件为 .env 并填写实际配置值

# ==================== 基础配置 ====================

# 服务端口
PORT=3000

# 运行环境（development/production）
NODE_ENV=production

# ==================== 安全配置 ====================

# JWT 密钥（生产环境请使用强密码）
# 生成方法：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-secret-key-change-in-production

# ==================== 数据存储路径 ====================

# 数据存储根目录
# 【重要】请根据实际部署环境修改，例如：
# - Linux/Mac: /home/youruser/data/pr-manager
# - Windows: D:/data/pr-manager
# - Docker Volume: /app/data（容器内路径，无需修改）
DATA_PATH=/app/data

# ==================== 代理配置 ====================

# HTTP 代理地址（用于爬虫访问国外网站）
# 【重要】如果部署在国内服务器，需要配置代理
# 格式：http://代理地址:端口
# 示例：http://clash:7890（Docker 容器内）
#      http://127.0.0.1:7890（本地开发）
HTTP_PROXY=http://clash:7890

# Bangumi API 基础地址（一般无需修改）
BANGUMI_API_BASE=https://api.bgm.tv

# ==================== 数据库配置 ====================

# 数据库文件名（相对于 DATA_PATH）
# SQLite 数据库会自动创建在：{DATA_PATH}/database/{DB_FILENAME}
DB_FILENAME=app.db

# ==================== 文件上传限制 ====================

# 单个文件最大大小（MB）
MAX_FILE_SIZE=500

# 上传分片大小（MB）
CHUNK_SIZE=10
