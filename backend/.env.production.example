# ==================== 生产环境配置 ====================
# 请复制此文件为 .env.production 并修改配置

# 运行环境
NODE_ENV=production

# 服务端口
PORT=3000

# JWT 密钥（⚠️ 必须修改！运行以下命令生成）
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# 默认管理员密码（⚠️ 必须修改！）
# node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
DEFAULT_PASSWORD=change-this-password

# 数据路径
DATA_PATH=/app/data
DB_PATH=/app/data/database/app.db
UPLOADS_PATH=/app/data

# CORS 允许的来源（多个用逗号分隔）
# 示例：CORS_ORIGIN=https://your-domain.com,https://another-domain.com
CORS_ORIGIN=https://your-domain.com

# 允许盗链检查的来源（多个用逗号分隔）
# 留空则不检查 Referer
ALLOWED_ORIGINS=https://your-domain.com

# Redis 配置（可选）
REDIS_HOST=redis
REDIS_PORT=6379

# 代理配置（可选）
# HTTP_PROXY=http://clash:7890